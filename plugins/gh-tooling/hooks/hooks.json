{
  "description": "PreToolUse hook to enforce gh-tooling MCP tools over bash gh CLI commands.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-gh-tools.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
