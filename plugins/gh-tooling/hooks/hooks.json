{
  "description": "SessionStart hook to inject MCP tool directives, PreToolUse hooks to enforce gh-tooling MCP tools over bash gh CLI commands and block MCP api tool bypass.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-gh-tools.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__plugin_gh-tooling_gh-tooling__api_read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-api-tools.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__plugin_gh-tooling_gh-tooling-write__api",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-api-tools.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
