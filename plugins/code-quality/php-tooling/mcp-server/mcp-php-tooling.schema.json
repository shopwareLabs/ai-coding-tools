{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/shopwareLabs/claude-code-plugins/plugins/code-quality/php-tooling/mcp-php-tooling.schema.json",
  "title": "PHP Tooling Configuration",
  "description": "Configuration for the php-tooling MCP server",
  "type": "object",
  "required": ["environment"],
  "properties": {
    "environment": {
      "type": "string",
      "enum": ["native", "docker", "vagrant", "ddev"],
      "description": "Execution environment for linting commands"
    },
    "docker": {
      "type": "object",
      "description": "Docker environment configuration",
      "properties": {
        "container": {
          "type": "string",
          "description": "Docker container name (required for docker environment)"
        },
        "workdir": {
          "type": "string",
          "default": "/var/www/html",
          "description": "Working directory inside the container"
        }
      }
    },
    "vagrant": {
      "type": "object",
      "description": "Vagrant environment configuration",
      "properties": {
        "workdir": {
          "type": "string",
          "default": "/vagrant",
          "description": "Working directory inside the VM"
        }
      }
    },
    "ddev": {
      "type": "object",
      "description": "DDEV environment configuration",
      "properties": {
        "workdir": {
          "type": "string",
          "default": "/var/www/html",
          "description": "Working directory inside DDEV"
        }
      }
    },
    "phpstan": {
      "type": "object",
      "description": "PHPStan tool defaults",
      "properties": {
        "config": {
          "type": "string",
          "description": "PHPStan configuration file path"
        },
        "memory_limit": {
          "type": "string",
          "pattern": "^[0-9]+[KMG]?$",
          "description": "PHP memory limit (e.g., '2G', '512M')"
        }
      }
    },
    "ecs": {
      "type": "object",
      "description": "ECS tool defaults",
      "properties": {
        "config": {
          "type": "string",
          "description": "ECS/PHP-CS-Fixer configuration file path"
        }
      }
    },
    "phpunit": {
      "type": "object",
      "description": "PHPUnit tool defaults",
      "properties": {
        "testsuite": {
          "type": "string",
          "description": "Default test suite to run"
        },
        "config": {
          "type": "string",
          "description": "PHPUnit configuration file path"
        }
      }
    },
    "console": {
      "type": "object",
      "description": "Symfony console command defaults",
      "properties": {
        "env": {
          "type": "string",
          "enum": ["dev", "prod", "test"],
          "description": "Default Symfony environment"
        },
        "verbosity": {
          "type": "string",
          "enum": ["quiet", "normal", "verbose", "very-verbose", "debug"],
          "description": "Default output verbosity"
        },
        "no_debug": {
          "type": "boolean",
          "description": "Disable debug mode by default"
        },
        "no_interaction": {
          "type": "boolean",
          "description": "Non-interactive mode by default"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "environment": { "const": "docker" }
        }
      },
      "then": {
        "required": ["docker"],
        "properties": {
          "docker": {
            "required": ["container"]
          }
        }
      }
    }
  ],
  "examples": [
    {
      "environment": "native"
    },
    {
      "environment": "docker",
      "docker": {
        "container": "shopware_app",
        "workdir": "/var/www/html"
      }
    },
    {
      "environment": "ddev",
      "phpstan": {
        "config": "phpstan.neon",
        "memory_limit": "2G"
      },
      "ecs": {
        "config": "ecs.php"
      }
    }
  ]
}
