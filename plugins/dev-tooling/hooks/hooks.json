{
  "description": "PreToolUse hooks to enforce MCP dev tools over bash equivalents. Blocks PHPStan, ECS, PHPUnit, bin/console, ESLint, Stylelint, Prettier, Jest, TSC, and build commands.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-php-tools.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-js-admin-tools.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-js-storefront-tools.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
