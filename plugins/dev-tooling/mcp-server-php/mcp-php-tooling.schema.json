{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/shopwareLabs/ai-coding-tools/plugins/dev-tooling/mcp-server-php/mcp-php-tooling.schema.json",
  "title": "PHP Tooling Configuration",
  "description": "Configuration for the php-tooling MCP server",
  "type": "object",
  "required": ["environment"],
  "properties": {
    "environment": {
      "type": "string",
      "enum": ["native", "docker", "docker-compose", "vagrant", "ddev"],
      "description": "Execution environment for linting commands"
    },
    "enforce_mcp_tools": {
      "type": "boolean",
      "default": true,
      "description": "Block bash commands that should use MCP tools instead. Set to false to allow direct CLI invocations."
    },
    "log_file": {
      "type": "string",
      "description": "Additional log file path. Relative paths resolve against the project root. The default server.log continues to be written; this file is strictly additive.",
      "examples": [".claude/mcp-php-tooling.log", "/tmp/mcp-debug.log"]
    },
    "docker": {
      "type": "object",
      "description": "Docker environment configuration",
      "properties": {
        "container": {
          "type": "string",
          "description": "Docker container name (required for docker environment)"
        },
        "workdir": {
          "type": "string",
          "default": "/var/www/html",
          "description": "Working directory inside the container"
        }
      }
    },
    "docker-compose": {
      "type": "object",
      "description": "Docker Compose environment configuration",
      "properties": {
        "service": {
          "type": "string",
          "default": "web",
          "description": "Compose service name that runs PHP"
        },
        "workdir": {
          "type": "string",
          "description": "Working directory inside the compose service. If empty, the service's default WORKDIR is used."
        },
        "file": {
          "type": "string",
          "description": "Optional path to a compose file. If empty, docker compose auto-discovers docker-compose.yml / compose.yml from the project root."
        }
      }
    },
    "vagrant": {
      "type": "object",
      "description": "Vagrant environment configuration",
      "properties": {
        "workdir": {
          "type": "string",
          "default": "/vagrant",
          "description": "Working directory inside the VM"
        }
      }
    },
    "ddev": {
      "type": "object",
      "description": "DDEV environment configuration",
      "properties": {
        "workdir": {
          "type": "string",
          "default": "/var/www/html",
          "description": "Working directory inside DDEV"
        }
      }
    },
    "phpstan": {
      "type": "object",
      "description": "PHPStan tool defaults",
      "properties": {
        "config": {
          "type": "string",
          "description": "PHPStan configuration file path"
        },
        "memory_limit": {
          "type": "string",
          "pattern": "^[0-9]+[KMG]?$",
          "description": "PHP memory limit (e.g., '2G', '512M')"
        }
      }
    },
    "ecs": {
      "type": "object",
      "description": "ECS tool defaults",
      "properties": {
        "config": {
          "type": "string",
          "description": "ECS/PHP-CS-Fixer configuration file path"
        }
      }
    },
    "rector": {
      "type": "object",
      "description": "Rector tool defaults",
      "properties": {
        "config": {
          "type": "string",
          "description": "Rector configuration file path"
        }
      }
    },
    "phpunit": {
      "type": "object",
      "description": "PHPUnit tool defaults",
      "properties": {
        "testsuite": {
          "type": "string",
          "description": "Default test suite to run"
        },
        "config": {
          "type": "string",
          "description": "PHPUnit configuration file path"
        },
        "coverage_driver": {
          "type": "string",
          "enum": ["xdebug", "pcov"],
          "description": "Default coverage driver."
        }
      }
    },
    "console": {
      "type": "object",
      "description": "Symfony console command defaults",
      "properties": {
        "env": {
          "type": "string",
          "enum": ["dev", "prod", "test"],
          "description": "Default Symfony environment"
        },
        "verbosity": {
          "type": "string",
          "enum": ["quiet", "normal", "verbose", "very-verbose", "debug"],
          "description": "Default output verbosity"
        },
        "no_debug": {
          "type": "boolean",
          "description": "Disable debug mode by default"
        },
        "no_interaction": {
          "type": "boolean",
          "description": "Non-interactive mode by default"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "environment": { "const": "docker" }
        }
      },
      "then": {
        "required": ["docker"],
        "properties": {
          "docker": {
            "required": ["container"]
          }
        }
      }
    }
  ],
  "examples": [
    {
      "environment": "native"
    },
    {
      "environment": "docker",
      "docker": {
        "container": "shopware_app",
        "workdir": "/var/www/html"
      }
    },
    {
      "environment": "ddev",
      "phpstan": {
        "memory_limit": "2G"
      }
    }
  ]
}
