{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/shopwareLabs/ai-coding-tools/plugins/dev-tooling/shared/mcp-js-tooling.schema.json",
  "title": "JS Tooling Configuration",
  "description": "Configuration for the JS tooling MCP servers (js-admin-tooling and js-storefront-tooling)",
  "type": "object",
  "required": ["environment"],
  "properties": {
    "environment": {
      "type": "string",
      "enum": ["native", "docker", "docker-compose", "vagrant", "ddev"],
      "description": "Execution environment for JavaScript commands"
    },
    "enforce_mcp_tools": {
      "type": "boolean",
      "default": true,
      "description": "Block bash commands that should use MCP tools instead. Set to false to allow direct CLI invocations."
    },
    "log_file": {
      "type": "string",
      "description": "Additional log file path. Relative paths resolve against the project root. The default server.log continues to be written; this file is strictly additive.",
      "examples": [".claude/mcp-js-tooling.log", "/tmp/mcp-debug.log"]
    },
    "docker": {
      "type": "object",
      "description": "Docker environment configuration",
      "properties": {
        "container": {
          "type": "string",
          "description": "Docker container name (required for docker environment)"
        },
        "workdir": {
          "type": "string",
          "default": "/var/www/html",
          "description": "Working directory inside the container"
        }
      }
    },
    "docker-compose": {
      "type": "object",
      "description": "Docker Compose environment configuration",
      "properties": {
        "service": {
          "type": "string",
          "default": "web",
          "description": "Compose service name that runs Node.js"
        },
        "workdir": {
          "type": "string",
          "description": "Working directory inside the compose service. If empty, the service's default WORKDIR is used."
        },
        "file": {
          "type": "string",
          "description": "Optional path to a compose file. If empty, docker compose auto-discovers docker-compose.yml / compose.yml from the project root."
        }
      }
    },
    "vagrant": {
      "type": "object",
      "description": "Vagrant environment configuration",
      "properties": {
        "workdir": {
          "type": "string",
          "default": "/vagrant",
          "description": "Working directory inside the VM"
        }
      }
    },
    "ddev": {
      "type": "object",
      "description": "DDEV environment configuration",
      "properties": {
        "workdir": {
          "type": "string",
          "default": "/var/www/html",
          "description": "Working directory inside DDEV"
        }
      }
    },
    "default_scope": {
      "type": "string",
      "description": "Scope name used when a tool is called without an explicit scope argument."
    },
    "scopes": {
      "type": "object",
      "not": { "required": ["shopware"] },
      "additionalProperties": {
        "type": "object",
        "required": ["cwd"],
        "properties": {
          "cwd": { "type": "string" },
          "jest": {
            "type": "object",
            "properties": {
              "cwd": { "type": "string", "description": "Jest working directory relative to scope cwd." },
              "env": {
                "type": "object",
                "description": "Environment variables exported before jest runs. Values pass through verbatim; relative paths inside values resolve against jest.cwd at runtime.",
                "additionalProperties": { "type": "string" }
              },
              "install_if_missing": {
                "type": "boolean",
                "description": "Run `npm ci` in jest.cwd when node_modules is absent."
              }
            }
          },
          "eslint":    { "type": "object", "properties": { "config": { "type": "string" } } },
          "stylelint": { "type": "object", "properties": { "config": { "type": "string" } } },
          "prettier":  { "type": "object", "properties": { "config": { "type": "string" } } },
          "tsc":       { "type": "object", "properties": { "config": { "type": "string" } } }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "environment": { "const": "docker" }
        }
      },
      "then": {
        "required": ["docker"],
        "properties": {
          "docker": {
            "required": ["container"]
          }
        }
      }
    }
  ],
  "examples": [
    {
      "environment": "native"
    },
    {
      "environment": "docker",
      "docker": {
        "container": "shopware_app",
        "workdir": "/var/www/html"
      }
    }
  ]
}
